{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python manage.py migrate && gunicorn insighta_labs.wsgi --bind 0.0.0.0:$PORT --workers 2 --timeout 120",
    "healthcheckPath": "/auth/whoami",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
